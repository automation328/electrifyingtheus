# Production build env (used by Vercel and `npm run build`).
# These are PUBLIC n8n webhook endpoints — safe to expose; they already ship in
# the client bundle and the n8n workflows allow all origins (CORS *).
# The OpenAI key is intentionally NOT set here, so the /assistant page runs in
# demo mode and no secret is ever shipped to the browser. The homepage EVA chat
# and the live gas-price map work via these n8n URLs.
VITE_N8N_WEBHOOK_URL=https://n8n-9odn.srv1570441.hstgr.cloud/webhook/957a20d3-4089-4135-8ff7-d4dace03c9a3/chat
VITE_GAS_PRICES_URL=https://n8n-9odn.srv1570441.hstgr.cloud/webhook/gas-prices
