# GoHighLevel integration for site forms.
# Set these in Vercel → Project → Settings → Environment Variables.
# Real values must NEVER be committed — .env / .env.local are gitignored.

# Private Integration Token (pit-…) for your GHL sub-account.
# IMPORTANT: rotate any token that was ever shared in plaintext.
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your GHL sub-account (location) id.
GHL_LOCATION_ID=

# Optional — set to a GHL user id to attach a details note to each contact.
GHL_USER_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Supabase — backs the dynamic Events + Blog posts submitted via the n8n form.
# The SITE uses the public anon key (read-only; RLS allows SELECT of published
# rows). The n8n workflow uses the SERVICE ROLE key (server-side only — NEVER
# put the service role key in any VITE_ var or the browser bundle).
# Without these the site falls back to the curated static events/blog content.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Google reCAPTCHA v3 — invisible spam scoring on all forms.
# Create keys at https://www.google.com/recaptcha/admin (choose "Score based v3").
# Site key is public (ships in the browser); secret key is server-only.
# Leave both blank to disable verification (forms still work).
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
